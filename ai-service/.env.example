DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
AI_SERVICE_INTERNAL_TOKEN=
AI_SERVICE_MAX_OUTPUT_TOKENS=1024

# ===== RAG 配置 =====
# 是否启用基于向量检索的 RAG 增强（仅作用于聊天场景）
RAG_ENABLED=true
# 每次检索返回的知识片段数量
RAG_TOP_K=3
# 最低相似度阈值（余弦相似度，0~1），低于该值的片段会被丢弃
RAG_MIN_SCORE=0.35
# 分段大小（字符数）
RAG_CHUNK_SIZE=400
# 相邻分段之间的重叠字符数
RAG_CHUNK_OVERLAP=60
# 用户查询向量的内存 LRU 缓存条数（设为 0 关闭缓存）
RAG_QUERY_CACHE_SIZE=256

# ----- Embedder 选择 -----
# qwen-local：本地千问 Qwen3-Embedding 系列（推荐，中文 SOTA，离线可用）
# dashscope：阿里云 DashScope 远程 embedding（按调用计费，无需本地 GPU）
# local：通用 sentence-transformers 加载（可指向 BGE / M3E 等其他模型）
RAG_EMBEDDER=qwen-local
# 通用 local embedder 使用的模型名（仅在 RAG_EMBEDDER=local 时生效）
RAG_MODEL_NAME=BAAI/bge-small-zh-v1.5

# ----- 千问本地 embedding（仅 RAG_EMBEDDER=qwen-local 时生效） -----
# 0.6B 模型 fp16 约 1.2GB；如有更高资源可换 4B / 8B
QWEN_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
# Qwen3-Embedding 推荐 query 端走 prompt_name=query，doc 端不传
QWEN_EMBED_QUERY_PROMPT_NAME=query
# 留空 = 自动检测 GPU/CPU；强制可填 cpu / cuda / mps
QWEN_EMBED_DEVICE=
# auto / float16 / bfloat16 / float32；CPU 一般用 auto 即可
QWEN_EMBED_DTYPE=auto
QWEN_EMBED_BATCH_SIZE=8

# ----- DashScope（阿里云）embedding 配置（仅 RAG_EMBEDDER=dashscope 时生效） -----
# 控制台获取：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_EMBED_MODEL=text-embedding-v3
DASHSCOPE_EMBED_DIM=1024
DASHSCOPE_TIMEOUT_SECONDS=30

# ----- 向量库选择（P2 新增） -----
# qdrant：使用 Qdrant 作为向量库（推荐，支持元数据过滤）；初始化失败会自动回退到 faiss
# faiss：本地 FAISS + numpy 兜底，零外部依赖
RAG_VECTOR_STORE=qdrant

# ----- Qdrant 配置（仅 RAG_VECTOR_STORE=qdrant 时生效） -----
# 远程模式（推荐）：docker compose up -d qdrant，与本仓库 ai-service/docker-compose.yml 配套
# 注意：若本机开启了系统代理（如 Clash / V2Ray），httpx（qdrant-client 底层）会读取
# Windows 注册表里的 ProxyServer 把请求丢给代理，导致连本地 Qdrant 也返回空 body 的
# 502 Bad Gateway。代码层已在 vector_stores.QdrantVectorStore 里通过追加 NO_PROXY
# 自动绕开此问题，因此 localhost / 127.0.0.1 都可使用，无需手动改系统代理。
QDRANT_URL=http://127.0.0.1:6333
# 嵌入式模式：填写本地目录后会忽略 QDRANT_URL。
# ⚠ 嵌入式目录同一时刻只能被一个 QdrantClient 占用。
#    uvicorn --reload 会起父子两个进程，都会初始化客户端 → 常见报错 «already accessed by another instance»。
#    解决：① 默认用法不要用嵌入式，改用上面 Docker；② 若坚持用嵌入式，请 uvicorn 不加 --reload。
# QDRANT_PATH=knowledge/.qdrant
QDRANT_API_KEY=
QDRANT_COLLECTION=mental_health_knowledge
QDRANT_PREFER_GRPC=false
QDRANT_TIMEOUT_SECONDS=30

# 国内访问 HuggingFace 直连大概率被墙（huggingface_hub 默认不读 Windows 系统代理，
# 即使本机开了 Clash/V2Ray 仍会直连超时）。建议启用国内镜像，对所有从 HF 拉模型的
# 场景都生效（qwen-local 嵌入器 / 重排器 / sentence-transformers 等）。
HF_ENDPOINT=https://hf-mirror.com
